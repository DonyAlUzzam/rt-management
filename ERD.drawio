        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n\n    RESIDENTS {\n        bigint id PK\n        varchar full_name\n        varchar ktp_photo\n        enum resident_type\n        varchar phone\n        enum marital_status\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    HOUSES {\n        bigint id PK\n        varchar house_number\n        text address\n        enum status\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    HOUSE_OCCUPANCIES {\n        bigint id PK\n        bigint house_id FK\n        bigint resident_id FK\n        date start_date\n        date end_date\n        boolean is_active\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    BILL_TYPES {\n        bigint id PK\n        varchar name\n        decimal amount\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    BILLS {\n        bigint id PK\n        bigint house_id FK\n        bigint resident_id FK\n        bigint bill_type_id FK\n        tinyint period_month\n        year period_year\n        decimal amount\n        enum status\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    PAYMENTS {\n        bigint id PK\n        date payment_date\n        decimal total_amount\n        text notes\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    PAYMENT_DETAILS {\n        bigint id PK\n        bigint payment_id FK\n        bigint bill_id FK\n        decimal amount\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    EXPENSE_CATEGORIES {\n        bigint id PK\n        varchar name\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    EXPENSES {\n        bigint id PK\n        bigint expense_category_id FK\n        date expense_date\n        text description\n        decimal amount\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    RESIDENTS ||--o{ HOUSE_OCCUPANCIES : occupies\n    HOUSES ||--o{ HOUSE_OCCUPANCIES : has_history\n\n    RESIDENTS ||--o{ BILLS : billed_to\n    HOUSES ||--o{ BILLS : generates\n    BILL_TYPES ||--o{ BILLS : contains\n\n    PAYMENTS ||--o{ PAYMENT_DETAILS : consists_of\n    BILLS ||--o{ PAYMENT_DETAILS : paid_by\n\n    EXPENSE_CATEGORIES ||--o{ EXPENSES : categorizes&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="1W-vruirVAZTXQuDe3vb-1">
